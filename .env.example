# ── Supabase (required for production) ──────────────────────────────────────
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Access control (optional) ────────────────────────────────────────────────
# Comma-separated email domains allowed to register (leave blank to allow anyone)
VITE_ALLOWED_EMAIL_DOMAINS=yourcompany.com

# Admin email promotion is configured in the database, not here.
# After deploy, set auto_promote_admin_emails in platform_auth_settings (see below).

# ── Microsoft SSO (optional) ─────────────────────────────────────────────────
# Register an app in Microsoft Entra ID, then enable Azure provider in Supabase:
# Authentication → Providers → Azure. Use the same tenant ID below for single-tenant login.
# VITE_AZURE_TENANT_ID=your-azure-directory-tenant-id
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
#
# Platform SSO policy is stored in Postgres (platform_auth_settings). After deploy, run:
# update public.platform_auth_settings set
#   allowed_email_domains = array['yourcompany.com'],
#   auto_promote_admin_emails = array['owner@yourcompany.com'],
#   microsoft_tenant_id = 'your-tenant-id',
#   enforce_microsoft_sso = false,
#   allow_email_password = true
# where id = 1;

# ── Email function URL (optional) ────────────────────────────────────────────
# Default points to the included Netlify function. Override if deploying on
# Vercel, Railway, or any other host.
# VITE_EMAIL_FUNCTION_URL=/api/send-ticket-email

# ── Email notifications via Resend (optional) ────────────────────────────────
# Set these in your Netlify / serverless environment — never use VITE_ prefix
# for secrets; these values must NOT be exposed to the browser.
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=StillDesk <bugs@yourdomain.com>
# STILLDESK_APP_URL=https://your-site.netlify.app
#
# The Netlify function also reads Supabase credentials server-side to verify
# the caller's session token before sending. Copy the same values without the
# VITE_ prefix:
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
